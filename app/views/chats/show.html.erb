<div class="chat-subnav row">
  <div class="col-1">
    <%= link_to user_chats_path(@user) do %>
      <i class="fa-solid fa-chevron-left"></i>
    <% end %>
  </div>
  <div class="col-11">
    <% if @user == @chat.owner %>
      <%= @chat.vet.clinic.clinic_name %>
    <% else %>
      <%= @chat.owner.name %>: <%= @chat.pet.name %>
    <% end %>
  </div>
</div>
<div class="msg-container-wrapper">
  <%= turbo_stream_from "chat_#{@chat.id}" %>
  <div
  class="msg-container"
  id="chat-messages"
  data-controller="scroll messages"
  data-messages-current-user-id-value="<%= current_user.id %>">
    <%= render @messages %>
    <div class="chat-bottom"> </div>
  </div>
  <%= form_with model: [@user, @chat, @message] do |f| %>
    <%= f.text_area :contents %>
    <button type="submit" class="send-btn" aria-label="Send message">
      <i class="fa-solid fa-arrow-up"></i>
    </button>
  <% end %>
</div>
<style>
  .message.from-me {
  flex-direction: row-reverse;
  }

  .message.from-me .msg {
  background: #dcf8c6;
  }

  .message.from-them .msg {
  background: #ffffff;
  }
</style>
